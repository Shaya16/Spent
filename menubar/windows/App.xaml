<Application x:Class="Spent.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="MenuRowBackground" Color="Transparent"/>
            <SolidColorBrush x:Key="MenuRowHoverBackground" Color="#14000000"/>
            <SolidColorBrush x:Key="StatusOnlineFill" Color="#34C759"/>
            <SolidColorBrush x:Key="StatusOfflineFill" Color="#8E8E93"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
