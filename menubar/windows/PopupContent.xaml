<UserControl x:Class="Spent.PopupContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Spent"
             Width="264"
             Background="Transparent">

    <UserControl.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <local:NotBoolToVisibilityConverter x:Key="NotBoolToVisibility"/>
        <local:StatusFillConverter x:Key="StatusFill"/>

        <Style x:Key="MenuRow" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background"
                                        Value="{StaticResource MenuRowHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
            BorderBrush="#22000000"
            BorderThickness="1"
            CornerRadius="10"
            Padding="0">
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.18" BlurRadius="14" ShadowDepth="2"/>
        </Border.Effect>

        <StackPanel>
            <!-- header -->
            <Grid Margin="14,14,14,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Path x:Name="HeaderLogo"
                      Grid.Column="0"
                      Width="24" Height="30"
                      Stroke="{DynamicResource {x:Static SystemColors.WindowTextBrushKey}}"
                      StrokeThickness="1.8"
                      StrokeStartLineCap="Flat" StrokeEndLineCap="Flat"
                      StrokeLineJoin="Miter"
                      VerticalAlignment="Center"
                      Margin="0,0,12,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Spent" FontSize="14" FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <Ellipse Width="6" Height="6"
                                 VerticalAlignment="Center"
                                 Fill="{Binding IsOnline, Converter={StaticResource StatusFill}}"/>
                        <TextBlock Margin="5,0,0,0"
                                   FontSize="11"
                                   Opacity="0.7"
                                   Text="{Binding StatusText}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Separator Margin="0" Background="#1A000000" Height="1"/>

            <!-- actions -->
            <StackPanel Margin="6">
                <Button Style="{StaticResource MenuRow}" Click="OpenDashboard_Click"
                        IsEnabled="{Binding IsOnline}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                        <TextBlock Grid.Column="1" Text="Open dashboard" Margin="10,0,0,0" FontSize="13"/>
                        <TextBlock Grid.Column="2" Text="Ctrl+O" FontSize="12" Opacity="0.6"/>
                    </Grid>
                </Button>
                <Button Style="{StaticResource MenuRow}" Click="SyncNow_Click"
                        IsEnabled="{Binding IsOnline}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                        <TextBlock Grid.Column="1" Text="Sync now" Margin="10,0,0,0" FontSize="13"/>
                        <TextBlock Grid.Column="2" Text="Ctrl+S" FontSize="12" Opacity="0.6"/>
                    </Grid>
                </Button>
            </StackPanel>

            <Separator Margin="0" Background="#1A000000" Height="1"/>

            <!-- service -->
            <StackPanel Margin="6">
                <Button Style="{StaticResource MenuRow}" Click="StopService_Click"
                        Visibility="{Binding IsOnline, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#E55353"/>
                        <TextBlock Grid.Column="1" Text="Stop service" Margin="10,0,0,0" FontSize="13" Foreground="#E55353"/>
                    </Grid>
                </Button>
                <Button Style="{StaticResource MenuRow}" Click="StartService_Click"
                        Visibility="{Binding IsOnline, Converter={StaticResource NotBoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#0A84FF"/>
                        <TextBlock Grid.Column="1" Text="Start service" Margin="10,0,0,0" FontSize="13" Foreground="#0A84FF"/>
                    </Grid>
                </Button>
            </StackPanel>

            <Separator Margin="0" Background="#1A000000" Height="1"/>

            <!-- quit -->
            <StackPanel Margin="6">
                <Button Style="{StaticResource MenuRow}" Click="Quit_Click">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="&#xE7E8;" FontFamily="Segoe MDL2 Assets" FontSize="13"/>
                        <TextBlock Grid.Column="1" Text="Quit menu bar" Margin="10,0,0,0" FontSize="13"/>
                        <TextBlock Grid.Column="2" Text="Ctrl+Q" FontSize="12" Opacity="0.6"/>
                    </Grid>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
